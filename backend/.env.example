# Database (Neon PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@endpoint.neon.tech/dbname?sslmode=require

# Redis (Upstash)
REDIS_URL=redis://default:password@region.upstash.io:6379

# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_from_botfather
TELEGRAM_BOT_SECRET=your_random_secret_for_validation

# Chapa Payment Gateway
CHAPA_SECRET_KEY=CHASECK_TEST-your_secret_key
CHAPA_WEBHOOK_SECRET=your_webhook_secret

# App Configuration
SECRET_KEY=your_random_secret_key_min_32_characters
COMMISSION_PERCENT=20.0
GAME_INTERVAL_SECONDS=1
COUNTDOWN_SECONDS=60

# CORS - Update with your Vercel URL
FRONTEND_URL=https://amhabingo.vercel.app
