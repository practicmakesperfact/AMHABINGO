# Database
# For SQLite (no installation needed):
DATABASE_URL=sqlite+aiosqlite:///./bingo.db
# For PostgreSQL (if installed):
# DATABASE_URL=postgresql+asyncpg://bingo:bingo123@localhost:5432/bingo

# Redis (optional - app works without it)
REDIS_URL=redis://localhost:6379

# Telegram (use test values for local development)
BOT_TOKEN=test_bot_token
TELEGRAM_BOT_SECRET=test_secret

# Chapa Payment (use test key for development)
CHAPA_SECRET_KEY=CHASECK_TEST-test_key
CHAPA_WEBHOOK_SECRET=test_webhook_secret

# App Settings
SECRET_KEY=your-secret-key-here-change-in-production
COMMISSION_PERCENT=10
GAME_INTERVAL_SECONDS=4

# CORS
FRONTEND_URL=http://localhost:3000
